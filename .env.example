# Servidor
PORT=3333
NODE_ENV=development

# Supabase
# Pegue em: Supabase > Project Settings > API
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key-aqui"
# ATENÇÃO: a service_role key ignora RLS e tem acesso total ao banco.
# Nunca exponha essa chave no frontend — ela fica só no backend.

# Autenticação
JWT_SECRET="troque-por-uma-chave-secreta-forte"
JWT_EXPIRES_IN="8h"

# CORS
FRONTEND_URL="http://localhost:5173"
